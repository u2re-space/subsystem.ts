{
    "include": [
        "**/*.ts",
        "**/*.mjs",
        "**/*.js",
        "**/*.d.ts",
        "**/*.tsx",
        "src/**/*.ts",
        "src/**/*.mjs",
        "src/**/*.js",
        "src/**/*.d.ts",
        "src/**/*.tsx",
        "../../modules/projects/**/*.ts",
        "../../modules/projects/**/*.tsx"
    ],
    "exclude": [
        "node_modules/**",
        "dist/**",
        "build/**",
        "coverage/**",
        "logs/**",
        "cache/**",
        "temp/**",
        "tmp/**",
        "temp/**",
        "./src/**/*.js",
        "./src/**/*.jsx"
    ],
    "compilerOptions": {
        "skipLibCheck": true,
        "jsx": "preserve",
        "paths": {
            "frontend/shared/*": [
                "./src/frontend/shared/*"
            ],
            "frontend/pwa/*": [
                "./src/frontend/pwa/*"
            ],
            "frontend/shells/*": [
                "./src/frontend/shells/*"
            ],
            "@phosphor-icons/core/assets/*": [
                "./node_modules/@phosphor-icons/core/assets/*"
            ],
            "icons/*": [
                "./node_modules/@phosphor-icons/core/assets/*"
            ],
            "assets/fonts/*": [
                "./assets/fonts/*"
            ],
            "assets/*": [
                "./assets/*"
            ],
            "shells/types": [
                "./src/frontend/shells/types.ts"
            ],
            "shells/boot": [
                "./src/frontend/boot/index.ts"
            ],
            "shells/window": [
                "./src/frontend/ai-slop/window/index.ts"
            ],
            "fest/core": [
                "./shared/fest/core/index.ts"
            ],
            "fest/dom": [
                "./shared/fest/dom/index.ts"
            ],
            "fest/fl-ui": [
                "./shared/fest/fl-ui/index.ts"
            ],
            "fest/lure": [
                "./shared/fest/lure/index.ts"
            ],
            "fest/object": [
                "./shared/fest/object/index.ts"
            ],
            "fest/object/*": [
                "./shared/fest/object/*"
            ],
            "fest/uniform": [
                "./shared/fest/uniform/index.ts"
            ],
            "fest/theme": [
                "./shared/fest/theme/index.ts"
            ],
            "fest/icon": [
                "./shared/fest/icon/index.ts"
            ],
            "fest/veela": [
                "./shared/fest/veela/index.ts"
            ],
            "fest/veela/*": [
                "./shared/fest/veela/*"
            ],
            "fest/polyfill/*": [
                "./shared/polyfill/*"
            ],
            "com/*": [
                "./src/*"
            ],
            "core/*": [
                "./src/*"
            ],
            "shared/*": [
                "./src/*"
            ],
            "@shared/*": [
                "./shared/*"
            ],
            "veela-lib": [
                "./shared/fest/veela/scss/index.scss"
            ],
            "veela-lib/*": [
                "./shared/fest/veela/scss/*"
            ]
        },
        "types": [
            "chrome"
        ],
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable",
            "WebWorker"
        ],
        "module": "ESNext",
        "target": "ESNext",
        "moduleDetection": "auto",
        "pretty": true,
        "allowArbitraryExtensions": true,
        "emitDeclarationOnly": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "bundler",
        "preserveSymlinks": true,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "esModuleInterop": true,
        "verbatimModuleSyntax": true,
        "allowJs": true,
        "noEmit": true,
        "strict": false,
        "strictNullChecks": false,
        "allowUnusedLabels": true,
        "noImplicitAny": false,
        "declaration": true,
        "noImplicitThis": false,
        "inlineSources": true,
        "inlineSourceMap": true,
        "sourceMap": false,
        "experimentalDecorators": true,
        "noEmitOnError": true,
        "noEmitHelpers": true
    },
    "compileOnSave": false
}
